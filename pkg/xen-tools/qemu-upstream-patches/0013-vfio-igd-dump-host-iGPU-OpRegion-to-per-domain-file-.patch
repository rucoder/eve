From 5a5e006da25172ce3a3ae890206dd6a40a7e369f Mon Sep 17 00:00:00 2001
From: Mikhail Malyshev <mike.malyshev@gmail.com>
Date: Thu, 7 May 2026 13:25:05 +0000
Subject: [PATCH 13/13] vfio/igd: dump host iGPU OpRegion to per-domain file
 (diagnostic)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Add a passive diagnostic dump of the host iGPU's OpRegion to a
per-domain file at /run/hypervisor/kvm/<qemu -name>/igd-opregion.bin
during the iGPU vfio probe, alongside the existing fw_cfg
publication.

Why:  OpRegion (which carries the VBT — Video BIOS Table — among
other host-specific structures) is one of the few pieces of
host-specific state QEMU forwards to the guest unchanged via
x-igd-opregion=on.  When iGPU passthrough misbehaves on one host
but not another, it helps to be able to diff VBT bytes between
hosts without a guest-side capture.

How:  uses the in-memory copy of OpRegion that
vfio_pci_igd_opregion_init() just read from the device fd via
pread().  No extra device access, no side effects.  Errors are
logged and ignored — the dump never blocks vfio probe.

Logs:
  IGD: OpRegion dumped to <path> (NN bytes, magic="...")
  IGD: OpRegion fopen <path>: <strerror>
  IGD: OpRegion fwrite to <path> failed

Signed-off-by: Mikhail Malyshev <mike.malyshev@gmail.com>
---
 hw/vfio/igd.c | 41 +++++++++++++++++++++++++++++++++++++++++
 1 file changed, 41 insertions(+)

diff --git a/hw/vfio/igd.c b/hw/vfio/igd.c
index 4bfa2e0fcd..a73e204484 100644
--- a/hw/vfio/igd.c
+++ b/hw/vfio/igd.c
@@ -18,6 +18,7 @@
 #include "hw/boards.h"
 #include "hw/hw.h"
 #include "hw/nvram/fw_cfg.h"
+#include "system/system.h"
 #include "pci.h"
 #include "pci-quirks.h"
 #include "trace.h"
@@ -166,6 +167,46 @@ static bool vfio_pci_igd_opregion_init(VFIOPCIDevice *vdev,
         return false;
     }
 
+    /*
+     * Diagnostic: dump the host iGPU's OpRegion to a per-domain file so
+     * the VBT contents can be inspected from outside the guest.  OpRegion
+     * is one of the few pieces of host-specific state QEMU forwards to the
+     * guest unchanged via x-igd-opregion=on, so when scanout misbehaves it
+     * helps to be able to compare VBT bytes across hosts without a
+     * guest-side capture.
+     *
+     * Path: /run/hypervisor/kvm/<qemu -name>/igd-opregion.bin
+     *
+     * Uses the in-memory copy we just read from the device — no extra
+     * device access, no side effects.  Errors are logged and ignored.
+     */
+    {
+        const char *vm_name = qemu_get_vm_name();
+        if (vm_name) {
+            g_autofree char *path = g_strdup_printf(
+                "/run/hypervisor/kvm/%s/igd-opregion.bin", vm_name);
+            FILE *f = fopen(path, "wb");
+            if (f) {
+                if (fwrite(vdev->igd_opregion, 1, info->size, f) == info->size) {
+                    const unsigned char *p = vdev->igd_opregion;
+                    error_report("IGD: OpRegion dumped to %s "
+                                 "(%u bytes, magic=\"%c%c%c%c%c%c%c%c"
+                                 "%c%c%c%c%c%c%c%c\")",
+                                 path, (unsigned)info->size,
+                                 p[0], p[1], p[2], p[3], p[4], p[5],
+                                 p[6], p[7], p[8], p[9], p[10], p[11],
+                                 p[12], p[13], p[14], p[15]);
+                } else {
+                    error_report("IGD: OpRegion fwrite to %s failed", path);
+                }
+                fclose(f);
+            } else {
+                error_report("IGD: OpRegion fopen %s: %s",
+                             path, strerror(errno));
+            }
+        }
+    }
+
     /*
      * Provide fw_cfg with a copy of the OpRegion which the VM firmware is to
      * allocate 32bit reserved memory for, copy these contents into, and write
-- 
2.43.0

