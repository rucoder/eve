From 99355402dbe75323e5d76076439b61e54c4207c2 Mon Sep 17 00:00:00 2001
From: Mikhail Malyshev <mike.malyshev@gmail.com>
Date: Thu, 7 May 2026 13:23:56 +0000
Subject: [PATCH 12/13] hw/isa/lpc_ich9: add x-device-id property to spoof PCH
 ID
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Backport of upstream QEMU's ICH9-LPC x-device-id property for
diagnostic use with Intel iGPU passthrough.  The proprietary
IntelGopDriver in OEM firmware does PCH detection by reading the LPC
bridge device ID at PCI 00:1f.0 and refuses to bind if the value isn't
a real Intel PCH.  q35's emulated ICH9 default 0x2918 is never on that
allow-list.

Adds:
  - ICH9LPCState::device_id_override (uint32_t)
  - DEFINE_PROP_UINT32 "x-device-id", default 0 (= use class default)
  - In ich9_lpc_realize, when override is non-zero, write it into the
    LPC PCI config-space device-ID field via pci_config_set_device_id().

Set on the QEMU command line via -global ICH9-LPC.x-device-id=0xa082
(or equivalent).  Diagnostic only — disagrees with QEMU's q35 ACPI
tables and emulated power management; do NOT enable for production.

Signed-off-by: Mikhail Malyshev <mike.malyshev@gmail.com>
---
 hw/isa/lpc_ich9.c             | 19 +++++++++++++++++++
 include/hw/southbridge/ich9.h |  9 +++++++++
 2 files changed, 28 insertions(+)

diff --git a/hw/isa/lpc_ich9.c b/hw/isa/lpc_ich9.c
index c9cb8f7779..36062ec5bf 100644
--- a/hw/isa/lpc_ich9.c
+++ b/hw/isa/lpc_ich9.c
@@ -711,6 +711,16 @@ static void ich9_lpc_realize(PCIDevice *d, Error **errp)
     ISABus *isa_bus;
     uint32_t irq;
 
+    /*
+     * Apply the optional x-device-id override before any code uses the
+     * device-ID field of PCI config space.  See struct ICH9LPCState for
+     * the rationale (diagnostic spoofing for proprietary GOP / SA
+     * drivers).
+     */
+    if (lpc->device_id_override != 0) {
+        pci_config_set_device_id(d->config, lpc->device_id_override);
+    }
+
     if ((lpc->smi_host_features & BIT_ULL(ICH9_LPC_SMI_F_CPU_HOT_UNPLUG_BIT)) &&
         !(lpc->smi_host_features & BIT_ULL(ICH9_LPC_SMI_F_CPU_HOTPLUG_BIT))) {
         /*
@@ -844,6 +854,15 @@ static const Property ich9_lpc_properties[] = {
                      pm.swsmi_timer_enabled, true),
     DEFINE_PROP_BOOL("x-smi-periodic-timer", ICH9LPCState,
                      pm.periodic_timer_enabled, true),
+    /*
+     * x-device-id: override the LPC's PCI device ID register.  Defaults
+     * to 0 which means "use class default 0x2918".  Set to a real-hardware
+     * PCH device ID (e.g. 0xa082 for a TGL-H WM490 PCH) to placate
+     * proprietary firmware drivers that whitelist real PCH models during
+     * PCH detection.  Diagnostic / debug knob — using a value disagreeing
+     * with QEMU's q35 ACPI tables risks ACPI / power-management mismatches.
+     */
+    DEFINE_PROP_UINT32("x-device-id", ICH9LPCState, device_id_override, 0),
 };
 
 static void ich9_send_gpe(AcpiDeviceIf *adev, AcpiEventStatusBits ev)
diff --git a/include/hw/southbridge/ich9.h b/include/hw/southbridge/ich9.h
index 2c35dd0484..262f56f77d 100644
--- a/include/hw/southbridge/ich9.h
+++ b/include/hw/southbridge/ich9.h
@@ -54,6 +54,15 @@ struct ICH9LPCState {
     uint8_t rst_cnt;
     MemoryRegion rst_cnt_mem;
 
+    /*
+     * Optional override for the LPC's PCI device ID, exposed as the
+     * x-device-id property.  Used to spoof real-hardware PCH IDs for
+     * proprietary Intel GOP / SA drivers that gate on the PCH model.
+     * 0 = use class default (PCI_DEVICE_ID_INTEL_ICH9_8 / 0x2918).
+     * Diagnostic only — disagrees with QEMU's q35 ACPI tables.
+     */
+    uint32_t device_id_override;
+
     /* SMI feature negotiation via fw_cfg */
     uint64_t smi_host_features;       /* guest-invisible, host endian */
     uint8_t smi_host_features_le[8];  /* guest-visible, read-only, little
